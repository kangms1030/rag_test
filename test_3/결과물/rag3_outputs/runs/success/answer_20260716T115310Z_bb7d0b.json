400</td><td rowspan=1 colspan=1></td></tr><tr><td rowspan=3 colspan=1>10Giga급</td><td rowspan=1 colspan=1>2.5G</td><td rowspan=1 colspan=1>300,000</td><td rowspan=1 colspan=1>10</td><td rowspan=1 colspan=1>60</td><td rowspan=1 colspan=1>180,000,000</td><td rowspan=1 colspan=1></td></tr><tr><td rowspan=1 colspan=1>5G</td><td rowspan=1 colspan=1>400,000</td><td rowspan=1 colspan=1>10</td><td rowspan=1 colspan=1>6</td><td rowspan=1 colspan=1>24,000,000</td><td rowspan=1 colspan=1>변심에 따른 해지</td></tr><tr><td rowspan=1 colspan=1>5G</td><td rowspan=1 colspan=1>400,000</td><td rowspan=1 colspan=1>30</td><td rowspan=1 colspan=1>48</td><td rowspan=1 colspan=1>576,000,000</td><td rowspan=1 colspan=1>해지로 인한 변동사항</td></tr><tr><td rowspan=1 colspan=1>10Giga급부가서비스</td><td rowspan=1 colspan=1></td><td rowspan=1 colspan=1>20,000</td><td rowspan=1 colspan=1>50</td><td rowspan=1 colspan=1>60</td><td rowspan=1 colspan=1>60,000,000</td><td rowspan=1 colspan=1></td></tr><tr><td rowspan=1 colspan=1>재해복구(DR)</td><td rowspan=1 colspan=1>1G</td><td rowspan=1 colspan=1>5,747,000</td><td rowspan=1 colspan=1>1</td><td rowspan=1 colspan=1>60</td><td rowspan=1 colspan=1>344,820,000</td><td rowspan=1 colspan=1></td></tr><tr><td rowspan=2 colspan=1>IPsec VPN</td><td rowspan=1 colspan=1>500M</td><td rowspan=1 colspan=1>31,900</td><td rowspan=1 colspan=1>10</td><td rowspan=1 colspan=1>60</td><td rowspan=1 colspan=1>19,140,000</td><td rowspan=1 colspan=1>해지에 따른 변동사항</td></tr><tr><td rowspan=1 colspan=1>500M</td><td rowspan=1 colspan=1>31,900</td><td rowspan=1 colspan=1>10</td><td rowspan=1 colspan=1>18</td><td rowspan=1 colspan=1>5,742,000</td><td rowspan=1 colspan=1>폐원에 따른해지</td></tr><tr><td rowspan=1 colspan=5>매출총액 합계</td><td rowspan=1 colspan=1>5,863,616,400</td><td rowspan=1 colspan=1></td></tr></table>",
