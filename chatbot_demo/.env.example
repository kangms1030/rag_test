# chatbot_demo 환경변수 예시 파일.
# 실제 값을 넣은 사본을 chatbot_demo/.env 로 저장하세요 (이 예시 파일에는 실제 키를 넣지 마세요).
# 로딩 우선순위: 프로세스 env > chatbot_demo/.env > 최상위 .env > 코드 기본값

# --- rag3x 연동 ---
# RAG3X_ROOT: rag3x/rag3 패키지가 들어있는 폴더 (sys.path에 추가됨). 미지정 시 자동 계산.
RAG3X_ROOT=C:\Users\minsoo\Desktop\아이티지엔 인턴\챗봇\test_3\코드
# RAG3X_CONFIG: rag3 config.yaml 경로. 미지정 시 RAG3X_ROOT\rag3\config.yaml.
RAG3X_CONFIG=C:\Users\minsoo\Desktop\아이티지엔 인턴\챗봇\test_3\코드\rag3\config.yaml
# 백엔드: gemini | ollama
RAG3X_BACKEND=gemini
# 엔진 warmup 시 딥 워밍업(모델을 VRAM에 상주) 여부
RAG3X_DEEP_WARMUP=false

# --- 유사도 매칭 (자유 입력 → 모범 질답) ---
SCENARIO_MATCH_THRESHOLD=0.90
SCENARIO_MATCH_MARGIN=0.05

# --- 웹검색 (기본 비활성) ---
WEB_SEARCH_ENABLED=false
# in_domain_unresolved | any_unresolved
WEB_SEARCH_SCOPE=in_domain_unresolved

# --- LangSmith 추적 ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=school-network-chatbot-demo
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- 서버 ---
DEMO_PORT=8001

# --- Gemini (rag3x 백엔드가 gemini일 때 필요) ---
# 최상위 .env의 GEMINI_API_KEY를 자동으로 읽으므로 보통 여기 넣지 않아도 됩니다.
# GEMINI_API_KEY=
